// KarmaFi database schema (PostgreSQL).
// Shapes intentionally mirror the flat objects the API/UI consume so the data
// layer maps 1:1 to the API routes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  walletAddress   String   @unique
  username        String?
  avatar          String?
  reputationScore Int      @default(50)
  role            String   @default("USER") // USER, ADMIN
  createdAt       DateTime @default(now())
}

model Market {
  id            String   @id @default(uuid())
  sourceHash    String   @unique
  tokenAddress  String
  marketAddress String   @unique
  creatorWallet String?
  curatorWallet String
  metadataUri   String
  status        String   @default("ACTIVE") // ACTIVE, HIDDEN, FLAGGED
  viralityScore Int      @default(0)
  marketCap     Float    @default(0)
  volume24h     Float    @default(0)
  holdersCount  Int      @default(0)
  createdAt     DateTime @default(now())
  // Denormalized display fields (Reddit post + token metadata)
  name          String
  symbol        String
  redditPostId  String
  subreddit     String
  author        String
  title         String
  permalink     String
  thumbnail     String?
  upvotes       Int      @default(0)
  comments      Int      @default(0)

  @@index([status])
}

model Trade {
  id           String   @id @default(uuid())
  marketId     String
  traderWallet String
  type         String // BUY, SELL
  bnbAmount    String
  tokenAmount  String
  price        String
  txHash       String
  createdAt    DateTime @default(now())

  @@index([marketId])
}

model Candle {
  id        String   @id @default(uuid())
  marketId  String
  timestamp DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float

  @@index([marketId, timestamp])
}

model CreatorClaim {
  id             String    @id @default(uuid())
  sourceHash     String    @unique
  redditUsername String
  walletAddress  String
  status         String    @default("PENDING") // PENDING, APPROVED, REJECTED
  proofReference String?
  claimedAt      DateTime?
  createdAt      DateTime  @default(now())
  amount         String    @default("0")
}

model ModerationReport {
  id             String   @id @default(uuid())
  marketId       String
  reporterWallet String
  reason         String
  details        String?
  status         String   @default("OPEN") // OPEN, RESOLVED, DISMISSED
  adminNotes     String?
  createdAt      DateTime @default(now())
}

model Watchlist {
  id        String   @id @default(uuid())
  userId    String
  marketId  String
  createdAt DateTime @default(now())

  @@unique([userId, marketId])
}

model ChainEvent {
  id              String   @id @default(uuid())
  eventName       String
  contractAddress String
  txHash          String
  blockNumber     Int
  payload         String
  processedAt     DateTime @default(now())

  @@unique([txHash, eventName])
}
